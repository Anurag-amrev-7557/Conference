# Local API dev overrides (loaded when NODE_ENV=development via npm run dev)
NODE_ENV=development
PORT=3001

SITE_URL=http://localhost:5173
API_PUBLIC_URL=http://localhost:3001

# Allow Vite dev server origins (required when testing from localhost:5173)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174
ADMIN_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

JWT_SECRET=dev-local-secret-change-me

# Uses DATABASE_URL from server/.env (Neon) unless you override here:
# DATABASE_URL=file:./dev.db
STORAGE_PROVIDER=local

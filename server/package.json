{
  "name": "book-website-api",
  "version": "1.0.0",
  "description": "Backend API for the Book Website (legacy alias: Superhumanly API)",
  "main": "dist/index.js",
  "scripts": {
    "dev": "NODE_ENV=development ts-node-dev --respawn --transpile-only src/start.ts",
    "build": "npx -p typescript@5.4.5 tsc",
    "build:render": "npm run build && prisma generate && prisma migrate deploy",
    "start": "node dist/start.js",
    "prisma:generate": "prisma generate",
    "postinstall": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "seed": "tsx src/seed.ts",
    "backup:db": "ts-node scripts/backup-db.ts",
    "cms:restore-registration": "ts-node src/scripts/restoreRegistrationCms.ts",
    "test": "vitest run"
  },
  "prisma": {
    "seed": "tsx src/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.12.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^1.4.13",
    "@types/node": "^20.19.41",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.10.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.1.0",
    "isomorphic-dompurify": "^3.13.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "prisma": "^5.12.1",
    "sharp": "^0.34.5",
    "sitemap": "^9.0.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/helmet": "^0.0.48",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.22.4",
    "typescript": "5.4.5",
    "vitest": "^4.1.6"
  }
}

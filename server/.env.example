PORT=3001
JWT_SECRET=your_super_secret_jwt_key_here

# CORS (SEC-05)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174
ADMIN_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# Marketing proxy (SEC-04) — server-only, never expose to Vite
MARKETING_BACKEND_URL=http://localhost:8000
MARKETING_API_KEY=your_marketing_master_key
# Alias supported: VELLUX_API_KEY (same value as marketing-backend VELLUX_MASTER_KEY)

# Backend (Render Web Service) — copy to Render Environment

NODE_ENV=production
PORT=3001

# Public site URL (Vercel) — used for CORS, sitemap, absolute links
SITE_URL=https://your-site.vercel.app

# This service's public URL — used in upload responses (/media, /og)
API_PUBLIC_URL=https://your-api.onrender.com

# CORS (optional if SITE_URL is set; comma-separated extra origins)
# ALLOWED_ORIGINS=https://your-site.vercel.app,https://www.yourdomain.com
# ADMIN_ALLOWED_ORIGINS=https://your-site.vercel.app

# Auth
JWT_SECRET=generate-a-long-random-string

# SQLite on persistent disk (Render: mount /var/data, set UPLOAD_ROOT=/var/data)
DATABASE_URL=file:/var/data/prod.db
UPLOAD_ROOT=/var/data

# Optional: backup SQLite on each API start (use with cron-style redeploys)
# BACKUP_ON_START=1

# Optional: override bootstrap source paths for hero assets
# BOOTSTRAP_HERO_VIDEO_PATH=/path/to/conference-hero.mp4
# BOOTSTRAP_LOGO_PATH=/path/to/logo.png

# Local development
# DATABASE_URL=file:./prisma/dev.db
# UPLOAD_ROOT=
# API_PUBLIC_URL=http://localhost:3001
# SITE_URL=http://localhost:5173

PORT=3001
NODE_ENV=development

# Public marketing site origin (canonical, OG, sitemap, JSON-LD) — not the API host
SITE_URL=https://monograph.superhumanly.ai

# Server-only secret: never expose this value to Vite/browser env files.
JWT_SECRET=replace_with_long_random_secret

# CORS (SEC-05)
# Public site origins (book website frontend)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174
# Admin panel origins (can be narrower than public origins)
ADMIN_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# Marketing proxy (SEC-04) — server-only, never expose to Vite
MARKETING_BACKEND_URL=http://localhost:8000
MARKETING_API_KEY=replace_with_marketing_backend_master_key
# Legacy alias supported for compatibility: VELLUX_API_KEY
# If both are present, MARKETING_API_KEY is used.

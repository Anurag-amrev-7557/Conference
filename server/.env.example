# Backend (Render Web Service) — copy to Render Environment

NODE_ENV=production
PORT=3001

# Public site URL — used for CORS, sitemap, absolute links, registration emails
SITE_URL=https://superhumanly-thoughts.com

# This service's public URL — used in upload responses (/media, /og)
API_PUBLIC_URL=https://your-api.onrender.com

# CORS extras (optional; SITE_URL + www + Firebase hosts are merged automatically in production)
# ALLOWED_ORIGINS=https://superhumanly-thoughts.com,https://www.superhumanly-thoughts.com,https://superhumanly-thoughts.web.app,https://superhumanly-thoughts.firebaseapp.com
# ADMIN_ALLOWED_ORIGINS=https://superhumanly-thoughts.com,https://www.superhumanly-thoughts.com,https://superhumanly-thoughts.web.app

# Auth
JWT_SECRET=generate-a-long-random-string

# Registration email (Resend — https://resend.com, free tier OK)
# RESEND_API_KEY=re_…
# EMAIL_FROM=Superhumanly Summit <notifications@yourdomain.com>
# REGISTRATION_NOTIFY_EMAIL=admin@yourcompany.com

# Database URL:
# Postgres (Neon/Supabase): postgresql://user:pass@host/db?sslmode=require
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# Storage provider (local | cloudinary)
STORAGE_PROVIDER=local

# Cloudinary (required when STORAGE_PROVIDER=cloudinary)
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# Optional: backup SQLite on each API start (use with cron-style redeploys)
# BACKUP_ON_START=1

# Keep-alive (free Render tier): GitHub Actions pings GET /ping every 5 min.
# Optional override secret: RENDER_HEALTHCHECK_URL=https://your-api.onrender.com/ping

# Optional: override bootstrap source paths for hero assets
# BOOTSTRAP_HERO_VIDEO_PATH=/path/to/conference-hero.mp4
# BOOTSTRAP_LOGO_PATH=/path/to/logo.png

# Local development (path is relative to prisma/schema.prisma)
# DATABASE_URL=file:./dev.db
# UPLOAD_ROOT=
# STORAGE_PROVIDER=local
# API_PUBLIC_URL=http://localhost:3001
# SITE_URL=http://localhost:5173

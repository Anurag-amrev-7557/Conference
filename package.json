{
  "name": "book-website",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "cms-bootstrap": "node scripts/generate-cms-bootstrap.mjs",
    "predev": "BOOTSTRAP_OPTIONAL=1 node scripts/generate-cms-bootstrap.mjs",
    "dev": "vite",
    "build": "node scripts/generate-cms-bootstrap.mjs && tsc -b && vite build && node scripts/prerender.mjs",
    "build:no-prerender": "node scripts/generate-cms-bootstrap.mjs && tsc -b && vite build",
    "build:staging": "vite build && node scripts/copy-spa-fallbacks.mjs",
    "vercel-build": "BOOTSTRAP_OPTIONAL=1 node scripts/generate-cms-bootstrap.mjs && tsc -b && vite build && PRERENDER_OPTIONAL=1 node scripts/prerender.mjs && SEO_STATIC_OPTIONAL=1 node scripts/fetch-seo-static.mjs && node scripts/strip-heavy-public.mjs",
    "firebase-build": "npm run build:no-prerender && SEO_STATIC_OPTIONAL=1 node scripts/fetch-seo-static.mjs && node scripts/strip-heavy-public.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "prerender": "node scripts/prerender.mjs",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "e2e:smoke": "node scripts/e2e-smoke.mjs",
    "smoke:production": "node scripts/smoke-production.mjs",
    "verify:phase15-gsc": "node scripts/verify-phase15-gsc.mjs",
    "verify:phase17": "node scripts/verify-phase17-nav-hero.mjs",
    "verify:phase20": "node scripts/verify-phase20-blog-index.mjs",
    "a11y:contrast": "node scripts/a11y-contrast.mjs",
    "a11y:static": "node scripts/a11y-static.mjs",
    "a11y:axe": "node scripts/a11y-audit.mjs",
    "a11y:at": "node scripts/a11y-at-audit.mjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource-variable/plus-jakarta-sans": "^5.2.8",
    "@fontsource/instrument-serif": "^5.2.8",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-visually-hidden": "^1.2.4",
    "@tailwindcss/typography": "^0.5.19",
    "@tiptap/extension-link": "^3.24.0",
    "@tiptap/extension-placeholder": "^3.24.0",
    "@tiptap/extension-underline": "^3.24.0",
    "@tiptap/react": "^3.24.0",
    "@tiptap/starter-kit": "^3.24.0",
    "@types/leaflet": "^1.9.21",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dompurify": "^3.4.7",
    "framer-motion": "^12.38.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.7.0",
    "marked": "^18.0.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-helmet-async": "^3.0.0",
    "react-leaflet": "^5.0.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.14.0",
    "tailwind-merge": "^3.5.0",
    "web-vitals": "^5.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.2",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.5.3",
    "jsdom": "^29.1.1",
    "playwright": "^1.52.0",
    "postcss": "^8.5.8",
    "puppeteer": "^25.0.4",
    "schema-dts": "^2.0.0",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "vite-plugin-compression": "^0.5.1",
    "vitest": "^4.1.6"
  }
}

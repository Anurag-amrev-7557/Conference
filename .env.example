# Book Website - Browser Environment (Vite)
# Only VITE_* variables are exposed to browser bundles.

# Book API base URL used by the frontend app.
# Local: http://localhost:3001/api/v1
# Production behind reverse proxy: https://your-domain.com/api/v1
VITE_API_URL=http://localhost:3001/api/v1

# Server / Compose (copy to .env for docker compose)
SITE_URL=http://localhost
JWT_SECRET=dev-only-change-in-production-min-32-chars
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
ADMIN_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Prerender (CI or post-publish — API must be running with seed data)
# PRERENDER_API_URL=http://127.0.0.1:3001
# PRERENDER_SKIP=1

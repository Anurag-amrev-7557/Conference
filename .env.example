# Frontend (Vercel) — copy to Vercel project Environment Variables

# Production API on Render (required)
VITE_API_URL=https://your-api.onrender.com/api/v1

# Optional: explicit API origin for /media and /og (defaults from VITE_API_URL)
# VITE_API_ORIGIN=https://your-api.onrender.com

# Admin login password for CMS (must match seeded admin on API)
VITE_ADMIN_PASSWORD=change-me

# Prerender at build time (Vercel build) — same host as Render API
PRERENDER_API_URL=https://your-api.onrender.com

# Skip prerender in CI when API is unavailable
# PRERENDER_SKIP=1

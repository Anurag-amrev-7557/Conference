# Frontend (Vercel) — copy to Vercel project Environment Variables

# Production API on Render (required)
VITE_API_URL=https://your-api.onrender.com/api/v1

# Optional: explicit API origin for /media and /og (defaults from VITE_API_URL)
# VITE_API_ORIGIN=https://your-api.onrender.com

# Prerender at build time (Vercel build) — API origin without /api/v1
PRERENDER_API_URL=https://your-api.onrender.com

# Skip prerender when API is unavailable (vercel-build uses PRERENDER_OPTIONAL=1 instead)
# PRERENDER_SKIP=1

# --- API server (Render) — optional CMS bootstrap publish hooks ---
# Default Firebase + Render setup needs NONE of these — live GET /api/v1/content/bootstrap is enough.
# See docs/FIREBASE_DEPLOY.md#cms-content-on-first-paint-no-cloud-functions-required

# CMS_BOOTSTRAP_PUBLISH_PATH=        # disk write (not for Firebase Hosting)
# CMS_BOOTSTRAP_PUBLISH_URL=         # custom webhook POST
# CMS_BOOTSTRAP_PUBLISH_TOKEN=       # Bearer secret for PUBLISH_URL
# CMS_BOOTSTRAP_DEPLOY_WEBHOOK_URL=  # Vercel deploy hook (optional static rebuild)

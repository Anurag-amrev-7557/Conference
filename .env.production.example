# Firebase Hosting + Render API — copy to .env.production before firebase-build
#
# 1. Deploy Render API first → copy its URL below
# 2. Set SITE_URL on Render to your canonical custom domain (https://superhumanly-thoughts.com)
# 3. npm run firebase-build && firebase deploy --only hosting

VITE_API_URL=https://book-website-api.onrender.com/api/v1
VITE_API_ORIGIN=https://book-website-api.onrender.com

# Must match admin password from server seed
VITE_ADMIN_PASSWORD=

# Optional — defaults to /media/conference-hero.mp4 on API after bootstrap
# VITE_CONFERENCE_HERO_VIDEO_URL=https://book-website-api.onrender.com/media/conference-hero.mp4
